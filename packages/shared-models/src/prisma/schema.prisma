datasource db {
  provider = "postgresql"
  url      = env("MONGODB_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  INACTIVE
  ACTIVE
}

enum MemberRole {
  GUEST
  MEMBER
  MANAGER
  LEADER
}

enum OrganizationRole {
  ADMIN
  MANAGER
  MEMBER
}

enum InvitationStatus {
  REJECTED
  ACCEPTED
  INVITING
}

enum TaskPriority {
  URGENT
  HIGH
  NORMAL
  LOW
}

enum StatusType {
  DONE
  INPROCESS
  TODO
}

enum ActivityObjectType {
  TASK
  PROJECT
}

model User {
  id                  Int                   @id @default(autoincrement()) @map("_id")
  email               String                @unique
  password            String
  name                String?
  status              UserStatus?
  country             String?
  bio                 String?
  photo               String?
  dob                 DateTime?
  members             Members[]
  settings            Json?
  organizationMembers OrganizationMembers[]
  createdAt           DateTime?
  createdBy           String?
  updatedAt           DateTime?
  updatedBy           String?
}

model Favorites {
  id        Int       @id @default(autoincrement()) @map("_id")
  name      String
  icon      String
  link      String
  uid       Int
  orgId     Int
  type      String
  createdAt DateTime?
  createdBy String?
  updatedAt DateTime?
  updatedBy String?
}

model Organization {
  id             Int       @id @default(autoincrement()) @map("_id")
  name           String    @unique
  slug           String    @unique
  cover          String?
  avatar         String?
  maxStorageSize Int?
  desc           String?
  createdAt      DateTime?
  createdBy      String?
  updatedAt      DateTime?
  updatedBy      String?
}

enum OrgStorageType {
  AWS_S3
  DIGITAL_OCEAN_S3
}

model OrganizationStorage {
  id             Int            @id @default(autoincrement()) @map("_id")
  type           OrgStorageType
  config         Json
  organizationId Int
  createdAt      DateTime?
  createdBy      String?
  updatedAt      DateTime?
  updatedBy      String?
}

model OrganizationMembers {
  id             Int              @id @default(autoincrement()) @map("_id")
  uid            Int
  status         InvitationStatus
  organizationId Int
  role           OrganizationRole
  users          User             @relation(fields: [uid], references: [id])
  createdAt      DateTime?
  createdBy      String?
  updatedAt      DateTime?
  updatedBy      String?
}

enum CounterType {
  TASK
  PROJECT
  ORGANIZATION
}

model Counter {
  id      Int         @id @default(autoincrement()) @map("_id")
  type    CounterType
  counter Int
}

model Test {
  id    Int    @id @default(autoincrement()) @map("_id")
  title String
  order Int
}

enum TaskType {
  TASK
  BUG
  NEW_FEATURE
  IMPROVEMENT
}

model Task {
  id      Int       @id @default(autoincrement()) @map("_id")
  title   String
  desc    String?
  dueDate DateTime?
  order   Int
  type    TaskType?

  checklistDone  Int?
  checklistTodos Int?

  cover            String?
  plannedStartDate DateTime?
  plannedDueDate   DateTime?
  startDate        DateTime?
  projectId        Int
  priority         TaskPriority?
  visionId         Int?
  taskStatusId     Int?
  tagIds           Int[]
  assigneeIds      Int[]
  fileIds          Int[]
  parentTaskId     Int?
  progress         Int?
  done             Boolean       @default(false)
  // do not store `point` as objectID, cuz we just need to fill the point value
  taskPoint        Int?

  createdBy String?
  createdAt DateTime?
  updatedBy String?
  updatedAt DateTime?
}

model TaskStatus {
  id        Int        @id @default(autoincrement()) @map("_id")
  name      String
  color     String
  order     Int
  projectId Int
  type      StatusType @default(TODO)
}

model TaskChecklist {
  id     Int       @id @default(autoincrement()) @map("_id")
  taskId Int
  title  String
  order  Int
  done   Boolean?
  doneAt DateTime?
}

// Tag used for Projects and Tasks
model Tag {
  id        Int    @id @default(autoincrement()) @map("_id")
  name      String
  color     String
  projectId Int
}

model TaskPoint {
  id        Int     @id @default(autoincrement()) @map("_id")
  point     Int
  projectId Int
  icon      String?
}

model TaskAutomation {
  id             Int       @id @default(autoincrement()) @map("_id")
  organizationId Int
  projectId      Int
  when           Json
  then           Json
  createdBy      String?
  createdAt      DateTime?
  updatedBy      String?
  updatedAt      DateTime?
}

model Scheduler {
  id             Int     @id @default(autoincrement()) @map("_id")
  organizationId Int
  projectId      Int
  cronId         String?

  trigger Json
  action  Json

  createdBy String?
  createdAt DateTime?
  updatedBy String?
  updatedAt DateTime?
}

enum FileType {
  FILE
  FOLDER
}

enum FileOwnerType {
  TASK
  DISCUSSION
  DOCUMENT
}

model FileStorage {
  id             Int            @id @default(autoincrement()) @map("_id")
  organizationId Int
  projectId      Int
  name           String
  keyName        String
  type           FileType
  url            String?
  size           Float?
  mimeType       String?
  parentId       String?
  owner          Int?
  ownerType      FileOwnerType?
  isDeleted      Boolean?       @default(false)
  createdBy      String?
  createdAt      DateTime?
  deletedAt      DateTime?
  deletedBy      String?
}

model Project {
  id            Int      @id @default(autoincrement()) @map("_id")
  name          String
  projectViewId Int?
  desc          String?
  cover         String?
  icon          String?
  isArchived    Boolean? @default(false)
  createdBy     String?

  // these count settings is used for counting the number of tasks by days
  countMemberTask  Boolean? @default(false)
  countProjectTask Boolean? @default(true)

  createdAt      DateTime?
  organizationId String
  updatedBy      String?
  updatedAt      DateTime?
}

model ProjectSettingNotification {
  id          Int      @id @default(autoincrement()) @map("_id")
  uid         Int
  projectId   Int
  taskChanges Boolean? @default(false)
  remind      Boolean? @default(false)
  overdue     Boolean? @default(false)

  createdBy String?
  createdAt DateTime?
}

enum ProjectViewType {
  DASHBOARD
  LIST
  BOARD
  CALENDAR
  TIMELINE
  GOAL
  TEAM
  ACTIVITY
}

model ProjectView {
  id        Int             @id @default(autoincrement()) @map("_id")
  name      String?
  type      ProjectViewType
  onlyMe    Boolean?
  icon      String?
  projectId Int?
  order     Int?
  data      Json?

  createdBy String?
  createdAt DateTime?
  updatedBy String?
  updatedAt DateTime?
}

model Vision {
  id             Int       @id @default(autoincrement()) @map("_id")
  name           String
  projectId      Int?
  organizationId Int?
  parentId       Int?
  startDate      DateTime?
  dueDate        DateTime?
  progress       Int?
  createdBy      String?
  createdAt      DateTime?
}

model Members {
  id        Int        @id @default(autoincrement()) @map("_id")
  projectId Int
  role      MemberRole
  users     User?      @relation(fields: [uid], references: [id])
  uid       Int?
  createdBy String?
  createdAt DateTime?
  updatedBy String?
  updatedAt DateTime?
}

enum StatsType {
  PROJECT_TASK_BY_DAY
  MEMBER_TASK_BY_DAY
}

model Stats {
  id        Int       @id @default(autoincrement()) @map("_id")
  type      StatsType
  data      Json?
  uid       Int?
  projectId Int?
  orgId     Int?
  year      Int
  month     Int
  date      Int
  updatedAt DateTime?
}

enum DashboardComponentType {
  LINE
  SUMMARY
  PIE
  LISTTAB
  LIST
  COLUMN
  BURNDOWN
  BURNUP
}

model DashboardComponent {
  id          Int                     @id @default(autoincrement()) @map("_id")
  dashboard   Dashboard?              @relation(fields: [dashboardId], references: [id])
  dashboardId Int?
  title       String?
  type        DashboardComponentType?
  config      Json?

  createdBy String?
  createdAt DateTime?
  updatedBy String?
  updatedAt DateTime?
}

model Dashboard {
  id                  Int                  @id @default(autoincrement()) @map("_id")
  dashboardComponents DashboardComponent[]
  title               String?              @default("Untitled")
  projectId           Int?
  isDefault           Boolean?             @default(false)
}

enum ActivityType {
  TASK_CREATED
  // TASK_CHANGED // change due date, task title, description
  TASK_TITLE_CHANGED
  TASK_DESC_CHANGED
  TASK_DUEDATE_CHANGED

  TASK_ASSIGNEE_ADDED
  TASK_ASSIGNEE_REMOVED

  TASK_STATUS_CREATED
  TASK_STATUS_CHANGED

  TASK_PROGRESS_CHANGED
  TASK_PRIORITY_CHANGED
  TASK_POINT_CHANGED
  TASK_VISION_CHANGED

  TASK_COMMENT_CREATED
  TASK_COMMENT_CHANGED
  TASK_COMMENT_REMOVED

  TASK_ATTACHMENT_ADDED
  TASK_ATTACHMENT_REMOVED
}

model Activity {
  id         Int                @id @default(autoincrement()) @map("_id")
  objectId   String
  objectType ActivityObjectType
  type       ActivityType
  createdBy  String
  data       Json?
  createdAt  DateTime
  updatedAt  DateTime?
  updatedBy  String?
}

model Comment {
  id        Int @id @default(autoincrement()) @map("_id")
  taskId    Int
  projectId Int

  content String

  createdBy String
  createdAt DateTime
  updatedAt DateTime
}
